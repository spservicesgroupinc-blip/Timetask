{
  "name": "copy-of-mervs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const fs = require('fs'); ['sw.js', 'manifest.json', 'icon.svg'].forEach(f => { if (fs.existsSync(f)) fs.copyFileSync(f, 'dist/' + f); })\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "react-dom": "18.2.0",
    "react": "18.2.0",
    "@google/genai": "^1.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
